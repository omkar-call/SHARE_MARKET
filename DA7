# ===== 🔹 Cell 1 : Imports & Downloads =====
import nltk
import docx
from nltk.tokenize import word_tokenize
from nltk.corpus import stopwords
from nltk.stem import PorterStemmer, WordNetLemmatizer
from nltk import pos_tag
from sklearn.feature_extraction.text import TfidfVectorizer

nltk.download('punkt')
nltk.download('stopwords')
nltk.download('wordnet')
nltk.download('averaged_perceptron_tagger')

# ===== 🔹 Cell 2 : Read DOCX File =====
def read_docx(file_path):
    doc = docx.Document(file_path)
    text = ""
    for para in doc.paragraphs:
        text += para.text + " "
    return text

text = read_docx("sample.docx")
print(text)

# ===== 🔹 Cell 3 : Tokenization & POS Tagging =====
tokens = word_tokenize(text)
print("Tokens:\n", tokens)

pos_tags = pos_tag(tokens)
print("POS Tags:\n", pos_tags)

# ===== 🔹 Cell 4 : Stopword Removal =====
stop_words = set(stopwords.words('english'))
filtered_tokens = [word for word in tokens if word.lower() not in stop_words]
print("After Stopword Removal:\n", filtered_tokens)

# ===== 🔹 Cell 5 : Stemming =====
stemmer = PorterStemmer()
stemmed_words = [stemmer.stem(word) for word in filtered_tokens]
print("Stemmed Words:\n", stemmed_words)

# ===== 🔹 Cell 6 : Lemmatization =====
lemmatizer = WordNetLemmatizer()
lemmatized_words = [lemmatizer.lemmatize(word) for word in filtered_tokens]
print("Lemmatized Words:\n", lemmatized_words)

# ===== 🔹 Cell 7 : TF-IDF =====
documents = [text]
vectorizer = TfidfVectorizer()
tfidf_matrix = vectorizer.fit_transform(documents)

print("TF-IDF Features:\n", vectorizer.get_feature_names_out())
print("TF-IDF Matrix:\n", tfidf_matrix.toarray())
